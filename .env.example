# DATABASE (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=savix
POSTGRES_USER=savix_user
POSTGRES_PASSWORD=your_secure_password_here

# REDIS (Session & Rate Limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# BACKEND SERVER
SERVER_PORT=8080

# JWT AUTHENTICATION
JWT_PUBLIC_KEY_PATH=file:./jwt-public-key.pem
JWT_PRIVATE_KEY_PATH=file:./jwt-private-key.pem
JWT_ISSUER=savix
JWT_AUDIENCE=savix-app

# COOKIES
COOKIE_DOMAIN=localhost

# FRONTEND
FRONTEND_URL=http://localhost:3000


# EMAIL (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Savix

# Secret token to authenticate proxy requests
PROXY_SECRET=generate_a_random_secret_here
# Backend URL for the proxy to forward requests to
PROXY_BASE=http://localhost:8080
# Public API URL (used by frontend)
NEXT_PUBLIC_API_BASE_URL=/api/proxy
